{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "allowJs": true,
    "noEmit": true,
    "types": ["node"],
    "resolveJsonModule": true,
    "lib": ["ES2022", "DOM"]
  },
  "include": [
    "lib/**/*.ts",
    "lib/**/*.tsx"
  ],
  "exclude": ["**/node_modules", "**/dist", "**/.expo"]
}
